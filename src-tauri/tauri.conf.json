{
  "$schema": "https://raw.githubusercontent.com/nicedoc/open-tauri/main/docs/.vitepress/public/tauri-v2.schema.json",
  "productName": "3D Model Viewer",
  "version": "1.1.1",
  "identifier": "com.faicad.3d-viewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:vite",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "3D Model Viewer",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["nsis", "appimage", "dmg"],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "fileAssociations": [
      {
        "ext": ["stl", "glb", "gltf", "3mf", "step", "stp", "obj", "ply", "fbx", "dae", "3ds", "usdz", "drc", "bvh", "vtk", "vtp", "xyz", "pdb", "nrrd", "gcode", "wrl", "vox", "kmz", "amf", "lwo", "md2", "pcd", "3dm"],
        "name": "3D Model File",
        "description": "3D Model File"
      }
    ]
  }
}
