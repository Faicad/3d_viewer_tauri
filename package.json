{
  "name": "3d_viewer_tauri",
  "version": "1.1.1",
  "description": "Faicad 3D Viewer Desktop Application (Tauri)",
  "author": "Faicad",
  "license": "LGPL-2.0-only",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "tauri dev",
    "dev:vite": "vite",
    "build": "tsc --noEmit && vite build",
    "build:tauri": "tauri build",
    "build:win": "pnpm build && tauri build --target x86_64-pc-windows-msvc",
    "lint": "eslint src/",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "test:unit": "vitest run",
    "test:components": "vitest run --config vitest.jsdom.config.ts",
    "test:e2e": "playwright test",
    "test:fast": "vitest run && vitest run --config vitest.jsdom.config.ts",
    "postinstall": "node scripts/copy-draco-wasm.mjs",
    "ci": "bash scripts/ci.sh",
    "version:sync": "node scripts/sync-version.mjs"
  },
  "dependencies": {
    "@needle-tools/three-animation-pointer": "^1.0.7",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "@types/three": "^0.184.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.0.8",
    "lucide-react": "^1.14.0",
    "postprocessing": "^6.39.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^7.14.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.1",
    "tslib": "^2.8.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/ui": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "standard-version": "^9.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "magic-string": "0.30.17"
  }
}
